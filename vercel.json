{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://pavio.tech/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "hostel-pms-azure.vercel.app"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/((?!privacy).*)",
      "destination": "/index.html"
    }
  ]
}
